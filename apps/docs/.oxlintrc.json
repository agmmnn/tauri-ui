{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "plugins": ["typescript", "react", "import", "nextjs"],
  "categories": {},
  "env": {
    "builtin": true
  },
  "settings": {
    "react": {
      "version": "19.2.4"
    },
    "tailwindcss": {
      "callees": ["clsx", "cva", "cn"]
    }
  },
  "ignorePatterns": ["node_modules/", "dist/"]
}
